function flySteps(from, to)
    local dist = (to - from).Magnitude
    if dist <= 6 then tpInstant(to - Vector3.new(0, 3, 0)) return end
    local steps = math.max(2, math.ceil(dist / FLY_STEP))
    for i = 1, steps do
        local hrp = getRoot()
        if not hrp then return end
        local hum = getHumanoid()
        if hum then hum.Sit = false end
        local nextPos = from:Lerp(to, i / steps)
        hrp.AssemblyLinearVelocity = Vector3.zero
        hrp.AssemblyAngularVelocity = Vector3.zero
        hrp.CFrame = CFrame.new(nextPos)
        task.wait(0.08)
    end
end

function segmentedFlyTo(targetPos)
    local hrp = getRoot()
    if not hrp or not targetPos then return false end
    local goal = targetPos + Vector3.new(0, 3, 0)
    local start = hrp.Position
    if (goal - start).Magnitude <= 6 then return tpInstant(targetPos) end
    for _, t in { 0.3, 0.6, 0.9, 1.0 } do
        hrp = getRoot()
        if not hrp then return false end
        flySteps(hrp.Position, start:Lerp(goal, t))
        if t < 1 then task.wait(SEGMENT_PAUSE) end
    end
    return true
end

