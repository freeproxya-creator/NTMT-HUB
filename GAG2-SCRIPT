function applyMovementBypass(dt)
    if not genv.ftgs_BypassMovement then return end
    if movementBypass or gardenActionLock or isCatchingPet or stealBusy or collectingMutation then return end
    local hum = getHumanoid()
    local hrp = getRoot()
    if not hum or not hrp then return end
    dt = dt or 0.016
    applyMovement()
    local dir = hum.MoveDirection
    if dir.Magnitude > 0.05 then
        local flat = Vector3.new(dir.X, 0, dir.Z)
        if flat.Magnitude > 0.01 then
            flat = flat.Unit
            local speed = desiredWalkSpeed
            local vel = Vector3.new(flat.X * speed, hrp.AssemblyLinearVelocity.Y, flat.Z * speed)
            hrp.AssemblyLinearVelocity = vel
            pcall(function() hrp.Velocity = vel end)
            if lastClientMovePos then
                local snapBack = (hrp.Position - lastClientMovePos).Magnitude
                if snapBack > 5 and dir.Magnitude > 0.08 then
                    local push = hrp.CFrame.Position + flat * speed * dt * 3
                    hrp.CFrame = CFrame.new(push + Vector3.new(0, 0.2, 0))
                    hrp.AssemblyLinearVelocity = vel
                    pcall(function() hrp.Velocity = vel end)
                end
            end
            lastClientMovePos = hrp.Position
            lastKnownMoveCF = hrp.CFrame
        end
    else
        lastClientMovePos = hrp.Position
        lastKnownMoveCF = hrp.CFrame
        hrp.AssemblyLinearVelocity = Vector3.new(0, hrp.AssemblyLinearVelocity.Y, 0)
        hrp.AssemblyAngularVelocity = Vector3.zero
    end
end

