    end
    if #batch == 0 then return end
    lastMailTime = os.clock()
    isSendingMail = true
    task.spawn(function()
        xpcall(function()
            local userId = lookupMailUserId(mailUsername)
            if userId then sendMailBatch(userId, batch, mailMessage ~= "" and mailMessage or "NTMT HUB") end
