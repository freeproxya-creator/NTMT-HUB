function tryAntiShovelKnockback()
    if not genv.ftgs_AntiHit then return end
    if movementBypass or gardenActionLock or isCatchingPet or stealBusy then return end
    local hrp = getRoot()
    local hum = getHumanoid()
    if not hrp or not hum then return end
    local shovelNearby = false
    for _, plr in Services.Players:GetPlayers() do
        if plr ~= LocalPlayer and playerHasShovelEquipped(plr) then
            local ohrp = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
            if ohrp and (ohrp.Position - hrp.Position).Magnitude <= 50 then
                shovelNearby = true
                break
            end
        end
    end
    local vel = hrp.AssemblyLinearVelocity
    local knocked = vel.Magnitude > 45 or math.abs(vel.Y) > 35
    if shovelNearby or knocked then
        hrp.AssemblyLinearVelocity = Vector3.zero
        hrp.AssemblyAngularVelocity = Vector3.zero
        if hum:GetState() == Enum.HumanoidStateType.Physics or hum:GetState() == Enum.HumanoidStateType.Freefall then
            hum:ChangeState(Enum.HumanoidStateType.Running)
        end
    end
end

