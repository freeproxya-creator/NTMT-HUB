            if spawn:GetAttribute("RainbowSeed") ~= true and spawn:GetAttribute("GoldSeed") ~= true and spawn:GetAttribute("MegaSeed") ~= true then continue end
            local prompt = spawn:FindFirstChildWhichIsA("ProximityPrompt", true)
            if not prompt then continue end
            local pos = spawn:IsA("BasePart") and spawn.Position or (spawn:IsA("Model") and spawn:GetPivot().Position)
