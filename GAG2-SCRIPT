function getPetExpireRemaining(ref, model)
    local now = Services.Workspace:GetServerTimeNow()
    local despawn = nil
    if ref then
        despawn = ref:GetAttribute("DespawnTime") or ref:GetAttribute("ExpireTime") or ref:GetAttribute("DespawnAt")
            or ref:GetAttribute("LifetimeEnd")
    end
    if type(despawn) ~= "number" and model then
        despawn = model:GetAttribute("DespawnTime") or model:GetAttribute("ExpireTime") or model:GetAttribute("DespawnAt")
    end
    if type(despawn) == "number" then
        return math.max(0, math.floor(despawn - now + 0.5))
    end
    return nil
end

