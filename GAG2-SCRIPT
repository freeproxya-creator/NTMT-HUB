function findNearestDropPrompt()
    local hrp = getRoot()
    if not hrp then return nil end
    local best, bestDist
    for _, item in Services.Workspace:GetDescendants() do
        if not item:IsA("ProximityPrompt") then continue end
        local action = (item.ActionText or ""):lower()
        if not (action:find("pick") or action:find("collect")) then continue end
        local parent = item.Parent
        if not parent or (OwnerPlot and parent:IsDescendantOf(OwnerPlot)) then continue end
        local part = parent:IsA("BasePart") and parent or parent:FindFirstChildWhichIsA("BasePart", true)
        if not part then continue end
        local d = (part.Position - hrp.Position).Magnitude
        if not bestDist or d < bestDist then best, bestDist = { prompt = item, part = part }, d end
    end
    return best
end

