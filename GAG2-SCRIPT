            function tabObj:Dropdown(d)
                local values = d.Values or {}
                local idx = 1
                local picked = {}
                if d.Value and not d.Multi then
                    for i, v in ipairs(values) do if v == d.Value then idx = i break end end
                end
                local hint = d.Multi and " (tap=cycle+toggle)" or " (tap=cycle)"
                local row = Instance.new("TextButton")
                row.Size = UDim2.new(1, -8, 0, 40)
                row.BackgroundColor3 = theme.btn
                row.Text = ""
