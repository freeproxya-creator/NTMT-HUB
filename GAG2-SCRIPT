        if not genv.ftgs_BypassMovement then return end
        if movementBypass or gardenActionLock or stealBusy or isCatchingPet then return end
        local hrp = getRoot()
        local hum = getHumanoid()
        if not hrp or not hum then return end
        if hum.MoveDirection.Magnitude > 0.05 or desiredWalkSpeed > 16 then
            lastKnownMoveCF = hrp.CFrame
        end
    end)
