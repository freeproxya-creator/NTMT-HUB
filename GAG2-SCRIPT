local function hookGardenRemotes()
    local function hook(name, fn)
        local r = Net.Garden and Net.Garden[name]
        if r and r.OnClientEvent then xpcall(function() r.OnClientEvent:Connect(fn) end, noopErr) end
    end
    hook("PlantAdded", function(uid, pid, data) if uid == myUserId then trackedPlants[pid] = data end end)
    hook("PlantRemoved", function(uid, pid) if uid == myUserId then trackedPlants[pid] = nil end end)
    hook("FruitAdded", function(uid, pid, fruitId, data)
        if uid ~= myUserId then return end
        if not trackedPlants[pid] then trackedPlants[pid] = { Fruits = {} } end
        if not trackedPlants[pid].Fruits then trackedPlants[pid].Fruits = {} end
        trackedPlants[pid].Fruits[fruitId] = data
    end)
    hook("FruitRemoved", function(uid, pid, fruitId)
        if uid ~= myUserId then return end
        local p = trackedPlants[pid]
        if p and p.Fruits then p.Fruits[fruitId] = nil end
    end)
    local sync = Net.Garden and Net.Garden.SyncAllGardens
    if sync and sync.OnClientEvent then
        xpcall(function()
            sync.OnClientEvent:Connect(function(data)
                for uid, info in pairs(data) do
                    if (tonumber(uid) or uid) == myUserId and info.Plants then trackedPlants = info.Plants end
                end
            end)
        end, noopErr)
    end
end
