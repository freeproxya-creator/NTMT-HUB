local function normalizePetName(s) return string.lower(string.gsub(s or "", "^%s*(.-)%s*$", "%1")) end
local function getPetDisplayName(species, size)
    local ok, d = xpcall(PetData.GetDisplayName, noopErr, species, size)
    if ok and type(d) == "string" then return d end
    ok, d = xpcall(PetData.GetSpeciesDisplayName, noopErr, species)
    if ok and type(d) == "string" then return d end
    return species
end
local function matchesPet(species, size, target)
    local t = normalizePetName(target)
    local d = normalizePetName(getPetDisplayName(species, size))
    local s = normalizePetName(getPetDisplayName(species, nil))
    return d == t or s == t or string.find(d, t, 1, true) or string.find(s, t, 1, true)
end

local function trackSeedBuy(name)
    local p = getSeedPrice(name)
    local e = BoughtSeeds[name]
    if e then e.amount += 1 else BoughtSeeds[name] = { amount = 1, price = p } end
end
local function trackGearBuy(name)
    local p = getGearPrice(name)
    local e = BoughtGears[name]
    if e then e.amount += 1 else BoughtGears[name] = { amount = 1, price = p } end
end
local function trackPetBuy(name, price)
    local e = BoughtPets[name]
    if e then e.amount += 1 else BoughtPets[name] = { amount = 1, price = price or 0 } end
end

local function isDataReady(data)
    if type(data) ~= "table" then return false end
    local maxAge = data.MaxAge or 0
    local age = data.Age or 0
    return maxAge <= 0 or age >= maxAge
end

local function tryHarvestOne()
    if not genv.ftgs_AutoHarvest then return end
    local n = 0
    local now = os.clock()
    for plantId, plantData in pairs(trackedPlants) do
        if type(plantData) ~= "table" then continue end
        local fruits = plantData.Fruits
        if type(fruits) == "table" then
            for fruitId, fruitData in pairs(fruits) do
                if isDataReady(fruitData) then
                    local key = tostring(plantId) .. "|" .. tostring(fruitId)
                    if not firedSet[key] and n < HARVEST_BATCH then
                        safeNetCall(Net.Garden and Net.Garden.CollectFruit, plantId, fruitId)
                        firedSet[key] = now
                        n += 1
                    end
                end
            end
        end
        if isDataReady(plantData) then
            local key = tostring(plantId) .. "|_plant"
            if not firedSet[key] and n < HARVEST_BATCH then
                safeNetCall(Net.Garden and Net.Garden.CollectFruit, plantId, "")
                firedSet[key] = now
                n += 1
            end
        end
    end
    for key, time in pairs(firedSet) do
        if now - time > 30 then firedSet[key] = nil end
    end
end

local function tryBuySeedsFast()
    if not genv.ftgs_AutoBuySeed and not genv.ftgs_AutoBuyAllSeed then return end
    local list = {}
    if genv.ftgs_AutoBuyAllSeed then
