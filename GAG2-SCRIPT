function getPetExpireRemaining(ref, model)
    local now = Services.Workspace:GetServerTimeNow()
    local function scanSource(source)
        if not source then return nil end
        local keys = {
            "DespawnTime", "ExpireTime", "DespawnAt", "LifetimeEnd", "EndTime",
            "DespawnAtTime", "TameDeadline", "RemovalTime", "DeleteTime",
        }
        for _, k in keys do
            local v = source:GetAttribute(k)
            if type(v) == "number" then return math.max(0, math.floor(v - now + 0.5)) end
        end
        local spawn = source:GetAttribute("SpawnTime") or source:GetAttribute("CreatedAt") or source:GetAttribute("SpawnedAt")
        local life = source:GetAttribute("Lifetime") or source:GetAttribute("Duration") or source:GetAttribute("DespawnDelay")
        if type(spawn) == "number" and type(life) == "number" then
            return math.max(0, math.floor(spawn + life - now + 0.5))
        end
        for _, ch in source:GetChildren() do
            if (ch:IsA("NumberValue") or ch:IsA("IntValue")) and string.find(string.lower(ch.Name), "despawn", 1, true) then
                return math.max(0, math.floor(ch.Value - now + 0.5))
            end
        end
        return nil
    end
    return scanSource(ref) or scanSource(model)
end

