local function tryAutoPlant()
    if not genv.ftgs_AutoPlant or plantingBusy or not setHasAny(selectedPlantSeeds) then return end
    if os.clock() - lastPlant < COOLDOWN.Plant then return end
    if not ensureNearGarden() then return end
    local seedName, tool = pickNextPlantSeed()
    if not tool then return end
    local pos = findEmptyGardenSpot()
    if not pos then return end
    lastPlant = os.clock()
    plantingBusy = true
    task.spawn(function()
        ensureNearGarden()
        equipTool(tool)
        tool = findSeedToolByName(seedName) or tool
        safeNetCall(Net.Plant and Net.Plant.PlantSeed, pos, seedName, tool)
