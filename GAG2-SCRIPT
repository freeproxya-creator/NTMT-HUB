function findGearMailCategory(gearName)
    local inv = PlayerReplica and PlayerReplica.Data and PlayerReplica.Data.Inventory
    if type(inv) == "table" then
        for _, cat in MAIL_GEAR_CATEGORIES do
            local bucket = inv[cat]
            if type(bucket) == "table" and bucket[gearName] then return cat end
        end
    end
    if type(gearName) == "string" then
        if gearName:find("Sprinkler") then return "Sprinklers" end
        if gearName:find("Watering Can") then return "WateringCans" end
        if gearName:find("Shovel") then return "Shovels" end
        if gearName:find("Trowel") then return "Trowels" end
    end
    return "Sprinklers"
end

function lookupMailUserId(username)
    if type(username) ~= "string" or username == "" then return nil end
    username = string.gsub(username, "^%s*@?(.-)%s*$", "%1")
    if username == "" then return nil end
    local mailbox = Net.Mailbox
    if not mailbox or not mailbox.LookupPlayer or type(mailbox.LookupPlayer.Fire) ~= "function" then return nil end
    local ok, userId = xpcall(function() return mailbox.LookupPlayer:Fire(username) end, noopErr)
    if ok and type(userId) == "number" and userId > 0 then return userId end
    return nil
end

function sendMailBatch(userId, batch, note)
    if type(userId) ~= "number" or #batch == 0 then return false end
    local mailbox = Net.Mailbox
    if not mailbox or not mailbox.SendBatch or type(mailbox.SendBatch.Fire) ~= "function" then return false end
    local ok, success = xpcall(function() return mailbox.SendBatch:Fire(userId, batch, note or "") end, noopErr)
    return ok and success == true
end

function tryAutoMail()
    if not genv.ftgs_AutoSendMail or isSendingMail then return end
    if mailUsername == "" then return end
    if os.clock() - lastMailTime < COOLDOWN.Mail then return end
    if not Net.Mailbox then return end
    local batch = {}
    if mailSeedName ~= "" and mailSeedAmount > 0 then
        batch[#batch + 1] = { Category = "Seeds", ItemKey = mailSeedName, Count = math.clamp(math.floor(mailSeedAmount), 1, MAIL_MAX_PER_GIFT) }
    end
    if mailGearName ~= "" and mailGearAmount > 0 then
        batch[#batch + 1] = { Category = findGearMailCategory(mailGearName), ItemKey = mailGearName, Count = math.clamp(math.floor(mailGearAmount), 1, MAIL_MAX_PER_GIFT) }
    end
    if #batch == 0 then return end
    lastMailTime = os.clock()
    isSendingMail = true
    task.spawn(function()
        xpcall(function()
            local userId = lookupMailUserId(mailUsername)
            if userId then sendMailBatch(userId, batch, mailMessage ~= "" and mailMessage or "NTMT HUB") end
        end, noopErr)
        task.wait(MAIL_SEND_GAP)
        isSendingMail = false
    end)
end

