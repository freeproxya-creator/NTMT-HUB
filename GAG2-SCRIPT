local function formatMmSs(totalSec)
    totalSec = math.max(0, math.floor(totalSec))
    return string.format("%dm%02ds", math.floor(totalSec / 60), totalSec % 60)
end

local function getPetExpireSeconds(ref, model)
    local now = Services.Workspace:GetServerTimeNow()
    for _, src in ipairs({ ref, model }) do
        if src then
            for _, attr in ipairs({ "DespawnTime", "ExpireTime", "DespawnAt", "ExpireAt", "EndTime" }) do
                local v = src:GetAttribute(attr)
                if type(v) == "number" and v > now then return v - now end
            end
        end
    end
    return 0
end

