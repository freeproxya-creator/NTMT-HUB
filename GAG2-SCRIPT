                box.TextColor3 = theme.text
                box.Text = (s.Title or "Slider") .. ": " .. tostring(val)
                box.Font = Enum.Font.Code
                box.TextSize = 12
                box.Parent = page
                box.FocusLost:Connect(function()
                    val = math.clamp(tonumber(box.Text:match("%d+")) or val, minV, maxV)
                    box.Text = (s.Title or "Slider") .. ": " .. tostring(val)
                    if s.Callback then s.Callback(val) end
                end)
