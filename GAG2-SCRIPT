    task.spawn(function()
        equipTool(shovel)
        task.wait(0.2)
        shovel, shovelName = findGearTool("Shovel", { "Advanced Shovel", "Common Shovel" })
        if not shovel then shovelBusy = false return end
        local removed = 0
        for _, target in list do
            if removed >= SHOVEL_BATCH then break end
            if not target.plantId then continue end
            safeNetCall(Net.Shovel and Net.Shovel.UseShovel, target.plantId, "", shovelName, shovel)
            if type(shovel.Activate) == "function" then xpcall(function() shovel:Activate() end, noopErr) end
            removed += 1
            task.wait(COOLDOWN.Shovel)
        end
        shovelBusy = false
    end)
end

