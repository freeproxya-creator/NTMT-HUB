function setHasAny(set) return next(set) ~= nil end

function normalizeSeedKey(name) return type(name) == "string" and string.gsub(name, "%s+", "") or name end
function seedNamesMatch(a, b) return a == b or normalizeSeedKey(a) == normalizeSeedKey(b) end

function seedInSet(set, name)
    if not setHasAny(set) then return true end
    for k in set do if seedNamesMatch(k, name) then return true end end
    return false
end

function buildPriorityList(selected, fallbackList)
    local out, seen = {}, {}
    for name in selected do
        if not seen[name] then out[#out + 1], seen[name] = name, true end
    end
    table.sort(out)
    if #out > 0 then return out end
    return fallbackList
