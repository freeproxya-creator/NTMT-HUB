function markHubScreenGuis()
    local roots = {}
    pcall(function() roots[#roots + 1] = LocalPlayer.PlayerGui end)
    if type(gethui) == "function" then pcall(function() roots[#roots + 1] = gethui() end) end
    pcall(function() roots[#roots + 1] = game:GetService("CoreGui") end)
    for _, root in roots do
        if not root then continue end
        for _, sg in root:GetChildren() do
            if not sg:IsA("ScreenGui") then continue end
            local isHub = sg:GetAttribute("NTMTHubUI") == true
            local n = string.lower(sg.Name or "")
            if not isHub and (n:find("ntmt", 1, true) or n:find("ntmthub", 1, true) or n:find("windui", 1, true)) then
                isHub = true
            end
            if not isHub then
                for _, d in sg:GetDescendants() do
                    if (d:IsA("TextButton") or d:IsA("TextLabel")) and type(d.Text) == "string" and d.Text:find("NTMT HUB", 1, true) then
                        isHub = true
                        break
                    end
                end
            end
            if isHub then
                sg:SetAttribute("NTMTHubUI", true)
                hubScreenGuis[sg] = true
            end
        end
    end
end

