local function plotUnlocked(player)
    if not player or not Gardens then return false end
    local plot
    for _, p in Gardens:GetChildren() do
        if p:GetAttribute("OwnerUserId") == player.UserId then plot = p break end
    end
    if not plot then return true end
    local area = plot:FindFirstChild("Visual") and plot.Visual:FindFirstChild("PlotSizeReferenceVisual")
    if not area then return true end
    for _, t in Services.Workspace:GetPartBoundsInBox(area.CFrame, area.Size) do
        if player.Character and t:IsDescendantOf(player.Character) then return false end
    end
    return true
end

local function calculateStealValue(fruit)
    local name = fruit:GetAttribute("CorePartName") or fruit:GetAttribute("PlantName")
    local size = fruit:GetAttribute("SizeMulti") or fruit:GetAttribute("Age")
    local mut = fruit:GetAttribute("Mutation")
    local ok, val = xpcall(FruitValueCalc, noopErr, name, size, mut, LocalPlayer, 1)
    return ok and val or 0
end

local function getPlotCenterPos(plot)
    if not plot then return nil end
    local psr = plot:FindFirstChild("PlotSizeReference")
    if psr and psr:IsA("BasePart") then return psr.Position end
    return plot:GetPivot().Position
end

local function getStealPrompt(fruit)
    local hp = fruit and fruit:FindFirstChild("HarvestPart")
    if not hp then return nil end
    local prompt = hp:FindFirstChild("StealPrompt")
    if prompt and not prompt:IsA("ProximityPrompt") then
        prompt = prompt:IsA("ObjectValue") and prompt.Value or hp:FindFirstChildWhichIsA("ProximityPrompt")
    end
    return prompt or hp:FindFirstChildWhichIsA("ProximityPrompt")
end

local function getStealableFruitsOnPlot(plot, limit)
    local list = {}
    if not plot then return list end
    local plants = plot:FindFirstChild("Plants")
    if not plants then return list end
    for _, plant in plants:GetChildren() do
        local fruits = plant:FindFirstChild("Fruits")
        local scan = fruits and fruits:GetChildren() or { plant }
        for _, fr in scan do
            if getStealPrompt(fr) then
                list[#list + 1] = { fruit = fr, value = calculateStealValue(fr) }
            end
        end
    end
    table.sort(list, function(a, b) return a.value > b.value end)
    local out = {}
    for i = 1, math.min(limit or STEAL_BATCH, #list) do out[#out + 1] = list[i].fruit end
    return out
end

local function findBestStealPlot()
    local bestPlot, bestOwner, bestValue = nil, nil, 0
    if not Gardens then return nil, nil end
    for _, plot in Gardens:GetChildren() do
        local oid = plot:GetAttribute("OwnerUserId")
        local owner = oid and Services.Players:GetPlayerByUserId(oid)
        if owner and owner ~= LocalPlayer and plotUnlocked(owner) then
            local fruits = getStealableFruitsOnPlot(plot, 1)
            if fruits[1] then
                local v = calculateStealValue(fruits[1])
                if v > bestValue then bestPlot, bestOwner, bestValue = plot, owner, v end
            end
        end
    end
    return bestPlot, bestOwner
end

local function fireProximityPrompt(prompt)
    if not prompt then return false end
    local fn = fireproximityprompt or rawget(genv, "fireproximityprompt")
    if type(fn) == "function" and select(1, xpcall(fn, noopErr, prompt, 0)) then return true end
    if type(prompt.InputHoldBegin) ~= "function" or type(prompt.InputHoldEnd) ~= "function" then return false end
    return xpcall(function()
        prompt:InputHoldBegin()
        if prompt.HoldDuration > 0 then task.wait(prompt.HoldDuration + 0.05) end
        prompt:InputHoldEnd()
    end, noopErr)
end

local function stealFruit(fruit, ownerUserId)
    if not fruit or not fruit.Parent then return false end
    local hp = fruit:FindFirstChild("HarvestPart")
    if not hp then return false end
    local stealPos = hp.Position
    local uid = ownerUserId or tonumber(fruit:GetAttribute("UserId"))
    local plantId = fruit:GetAttribute("PlantId")
    local fruitId = fruit:GetAttribute("FruitId") or ""
    if not uid or not plantId then return false end

    local fruitCountBefore = getFruitCount()
    movementBypass = true

    for _ = 1, 25 do
        if isStealComplete(fruit, fruitCountBefore) then break end
        tpInstant(stealPos)
        task.wait(0.06)
        local hrp = getRoot()
        if hrp then
            hrp.AssemblyLinearVelocity = Vector3.zero
            hrp.CFrame = CFrame.new(stealPos + Vector3.new(0, 3, 0))
        end
        local prompt = getStealPrompt(fruit)
        if prompt then fireProximityPrompt(prompt) end
        safeNetCall(Net.Steal and Net.Steal.BeginSteal, uid, plantId, fruitId)
        task.wait(0.05)
        safeNetCall(Net.Steal and Net.Steal.CompleteSteal)
        task.wait(0.08)
    end

    movementBypass = false

    if isStealComplete(fruit, fruitCountBefore) then
        StolenFruits[#StolenFruits + 1] = { name = fruit.Name .. " (" .. tostring(calculateStealValue(fruit)) .. ")", time = os.time() }
        saveConfig()
        return true
    end
    return false
end

local function tryAutoSteal()
    if not genv.ftgs_AutoSteal or stealBusy or isInventoryFull() then return end
    stealBusy = true
    task.spawn(function()
        movementBypass = true
        local plot, owner = findBestStealPlot()
        if plot and owner and plotUnlocked(owner) then
            local fruits = getStealableFruitsOnPlot(plot, STEAL_BATCH)
            for i = 1, math.min(STEAL_BATCH, #fruits) do
                if isInventoryFull() or not plotUnlocked(owner) then break end
                stealFruit(fruits[i], owner.UserId)
                task.wait(0.05)
            end
        end
        movementBypass = false
        stealBusy = false
    end)
end

