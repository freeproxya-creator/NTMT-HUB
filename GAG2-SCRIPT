        if genv.ftgs_AntiHit and not movementBypass and not gardenActionLock and not isCatchingPet and not collectingMutation
            and not plantingBusy and not sprinklerBusy and not shovelBusy and not stealBusy then
            local hrp, cf = getRoot(), getPlotCenterCFrame()
            if hrp and cf and (hrp.Position - cf.Position).Magnitude > 35 then
                hrp.AssemblyLinearVelocity = Vector3.zero
                hrp.AssemblyAngularVelocity = Vector3.zero
                hrp.CFrame = cf
            end
        end
        task.wait(0.08)
    end
end)

