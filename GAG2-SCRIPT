    if writefile and isfile and getcustomasset then
        local fileName = "ntmthub/bg_" .. tostring(themeName or "theme") .. ".png"
        if not isfile(fileName) then
            local body = universalHttpGet(url)
            if type(body) == "string" and #body > 128 then
                pcall(function()
                    if makefolder then pcall(makefolder, "ntmthub") end
                    writefile(fileName, body)
                end)
            end
        end
        if isfile(fileName) then
            local ok, asset = pcall(getcustomasset, fileName)
            if ok and type(asset) == "string" and asset ~= "" then return asset end
        end
    end
    return url
end

function estimateFrameArea(frame)
    if not frame or not frame:IsA("GuiObject") then return 0 end
    local sz = frame.AbsoluteSize
    local area = sz.X * sz.Y
    if area > 0 then return area end
    local cam = workspace.CurrentCamera
    if not cam then return 0 end
    local vx = frame.Size.X.Offset + frame.Size.X.Scale * cam.ViewportSize.X
    local vy = frame.Size.Y.Offset + frame.Size.Y.Scale * cam.ViewportSize.Y
    return vx * vy
end

