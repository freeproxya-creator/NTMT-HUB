local function holdGardenStill(duration)
    refreshOwnerPlot()
    if not savedPlotCenter then return end
    local cf = CFrame.new(savedPlotCenter + Vector3.new(0, 3, 0))
    gardenActionLock = true
    movementBypass = true
    local deadline = os.clock() + (duration or 0.5)
    while os.clock() < deadline do
        local hrp = getRoot()
        local hum = getHumanoid()
        if hrp then
            hrp.AssemblyLinearVelocity = Vector3.zero
            hrp.AssemblyAngularVelocity = Vector3.zero
            hrp.CFrame = cf
        end
        if hum then hum.PlatformStand = true end
        task.wait(0.04)
    end
    local hum = getHumanoid()
    if hum then hum.PlatformStand = false end
    gardenActionLock = false
end

local function parseMultiSelect(sel, into)
    table.clear(into)
    if type(sel) ~= "table" then return end
    for k, v in pairs(sel) do
        if type(v) == "string" then into[v] = true
        elseif type(k) == "string" and v then into[k] = true end
    end
end

local function setHasAny(set) return next(set) ~= nil end

local function seedInSet(set, name)
    if not setHasAny(set) then return true end
    for k in set do if seedNamesMatch(k, name) then return true end end
    return false
end

local function buildPriorityList(selected, fallbackList)
    local out, seen = {}, {}
    for name in selected do
        if not seen[name] then out[#out + 1], seen[name] = name, true end
    end
    table.sort(out)
    if #out > 0 then return out end
    return fallbackList
end

local function isNearGarden(maxDist)
    refreshOwnerPlot()
    if not savedPlotCenter then return false end
    local hrp = getRoot()
    if not hrp then return false end
    maxDist = maxDist or GARDEN_NEAR_DIST
    local flat = Vector3.new(hrp.Position.X, 0, hrp.Position.Z) - Vector3.new(savedPlotCenter.X, 0, savedPlotCenter.Z)
    return flat.Magnitude <= maxDist
end

local function ensureNearGarden()
    refreshOwnerPlot()
    if not savedPlotCenter then return false end
    if isNearGarden() then return true end
    local hrp = getRoot()
    if not hrp then return false end
    movementBypass = true
    hrp.AssemblyLinearVelocity = Vector3.zero
    hrp.AssemblyAngularVelocity = Vector3.zero
    hrp.CFrame = CFrame.new(savedPlotCenter + Vector3.new(0, 3, 0))
    movementBypass = false
    return true
end

local function matchesAnySelectedPet(species, size)
    if not setHasAny(selectedPets) then return false end
    for petName in selectedPets do
        if matchesPet(species, size, petName) then return true end
    end
    return false
end

local function getRarityRank(rarity) return RARITY_RANK[rarity] or 99 end
local function getSeedRarity(seedName) local i = SeedDataByName[seedName] return i and i.Rarity or "Common" end
local function getSeedPrice(name)
    local info = SeedDataByName[name]
    if not info then return math.huge end
    return (safeFlagGet(SeedShopFlags and SeedShopFlags.PriceOverrides))[name] or info.PurchasePrice
end
local function getGearPrice(name)
    local info = GearDataByName[name]
    if not info then return math.huge end
    return (safeFlagGet(GearShopFlags and GearShopFlags.PriceOverrides))[name] or info.Cost or math.huge
end

local function normalizeSeedKey(name) return type(name) == "string" and string.gsub(name, "%s+", "") or name end
local function seedNamesMatch(a, b) return a == b or normalizeSeedKey(a) == normalizeSeedKey(b) end

local function findGearTool(attrName, priority)
    local found = {}
    local function scan(c)
        if not c then return end
        for _, item in c:GetChildren() do
            if item:IsA("Tool") then local n = item:GetAttribute(attrName) if n then found[n] = item end end
        end
    end
    scan(LocalPlayer.Character)
    scan(LocalPlayer:FindFirstChild("Backpack"))
    for _, name in priority do if found[name] then return found[name], name end end
    return nil, nil
end

local function findSeedToolByName(seedName)
    local function scan(c)
        if not c then return end
        for _, item in c:GetChildren() do
            if item:IsA("Tool") then
                local attr = item:GetAttribute("SeedTool")
                if attr and seedNamesMatch(attr, seedName) then return item, attr end
            end
        end
    end
    return scan(LocalPlayer.Character) or scan(LocalPlayer:FindFirstChild("Backpack"))
end

local function pickNextPlantSeed()
    for name in selectedPlantSeeds do
        local tool = findSeedToolByName(name)
        if tool then return name, tool end
    end
    for _, name in SeedNames do
        if selectedPlantSeeds[name] then
            local tool = findSeedToolByName(name)
            if tool then return name, tool end
        end
    end
    return nil, nil
end

local function equipTool(tool)
    if not tool then return end
    local hum = getHumanoid()
    if hum and tool.Parent ~= LocalPlayer.Character then hum:EquipTool(tool) task.wait(0.12) end
end

local function getSeedStock(name)
    local item = StockItems:FindFirstChild(name)
    local maxStock = item and item.Value or 0
    local bought = 0
    if PlayerReplica and PlayerReplica.Data and PlayerReplica.Data.PurchasedThisRestock then
        bought = (PlayerReplica.Data.PurchasedThisRestock.Seeds or {})[name] or 0
    end
    return math.max(maxStock - bought, 0)
end

local function getGearStock(name)
    local item = GearStockItems:FindFirstChild(name)
    local maxStock = item and item.Value or 0
    local bought = 0
    if PlayerReplica and PlayerReplica.Data and PlayerReplica.Data.PurchasedThisRestock then
        bought = (PlayerReplica.Data.PurchasedThisRestock.Gears or {})[name] or 0
    end
    return math.max(maxStock - bought, 0)
end

local function countSeedOwned(name)
    local n = 0
    local function scan(c)
        if not c then return end
        for _, item in c:GetChildren() do
            if item:IsA("Tool") and seedNamesMatch(item:GetAttribute("SeedTool"), name) then n += 1 end
        end
    end
    local pf = OwnerPlot and OwnerPlot:FindFirstChild("Plants")
    if pf then
        for _, plant in pf:GetChildren() do
            local sn = plant:GetAttribute("SeedName") or plant:GetAttribute("PlantName")
            if seedNamesMatch(sn, name) then n += 1 end
        end
    end
    scan(LocalPlayer.Character)
    scan(LocalPlayer:FindFirstChild("Backpack"))
    return n
end

local function getOccupiedPlantPositions()
    local positions = {}
    refreshOwnerPlot()
    local pf = OwnerPlot and OwnerPlot:FindFirstChild("Plants")
    if not pf then return positions end
    for _, plant in pf:GetChildren() do
        local part = plant.PrimaryPart or plant:FindFirstChildWhichIsA("BasePart", true)
        if part then positions[#positions + 1] = part.Position end
    end
    return positions
end

local function isSpotEmpty(pos, occupied)
    for _, p in occupied do
        if (Vector3.new(p.X, 0, p.Z) - Vector3.new(pos.X, 0, pos.Z)).Magnitude < PLANT_MIN_DIST then return false end
    end
    return true
end

local function findEmptyGardenSpot()
    refreshOwnerPlot()
    if #plantAreas == 0 then refreshPlantAreas() end
    local occupied = getOccupiedPlantPositions()
    local empty = {}
    for _, pos in plantAreas do if isSpotEmpty(pos, occupied) then empty[#empty + 1] = pos end end
    if #empty > 0 then return empty[math.random(1, #empty)] end
    return nil
end

local function extractPlantDataPosition(plantData)
    if type(plantData) ~= "table" then return nil end
    local positions = plantData.Positions or plantData.Position
    if typeof(positions) == "Vector3" then return positions end
    if type(positions) == "table" then
        local x = positions.PosX or positions.X or positions.x
        local y = positions.PosY or positions.Y or positions.y
        local z = positions.PosZ or positions.Z or positions.z
        if x and y and z then return Vector3.new(x, y, z) end
    end
    return nil
end

local function findPlantAreaPosition(nearPos)
    if #plantAreas == 0 then refreshPlantAreas() end
    if #plantAreas == 0 or not nearPos then return nil end
    local bestPos, bestDist
    for _, pos in plantAreas do
        local d = (Vector3.new(pos.X, 0, pos.Z) - Vector3.new(nearPos.X, 0, nearPos.Z)).Magnitude
        if not bestDist or d < bestDist then bestPos, bestDist = pos, d end
    end
    return bestPos
end

local function findBestSprinklerSpot()
    refreshOwnerPlot()
    local bestPos, bestScore = nil, -math.huge
    for _, pd in pairs(trackedPlants) do
        local seed = getPlantSeedName(pd)
        if seed then
            local rank = getRarityRank(getSeedRarity(seed))
            local pos = extractPlantDataPosition(pd)
            if pos and rank <= 4 then
                local score = (5 - rank) * 1000 + getSeedPrice(seed)
                if score > bestScore then bestScore, bestPos = score, findPlantAreaPosition(pos) or pos end
            end
        end
    end
    local pf = OwnerPlot and OwnerPlot:FindFirstChild("Plants")
    if pf then
        for _, plant in pf:GetChildren() do
            local seed = plant:GetAttribute("SeedName") or plant:GetAttribute("PlantName")
            if seed then
                local rank = getRarityRank(getSeedRarity(seed))
                local part = plant.PrimaryPart or plant:FindFirstChildWhichIsA("BasePart", true)
                if part and rank <= 4 then
                    local score = (5 - rank) * 1000 + getSeedPrice(seed)
                    if score > bestScore then bestScore, bestPos = score, findPlantAreaPosition(part.Position) or part.Position end
                end
            end
        end
    end
    return bestPos or findEmptyGardenSpot() or savedPlotCenter
end

