function setupShopRestockWatch()
    local function bindFolder(folder)
        if not folder then return end
        for _, key in { "RestockToken", "RestockId", "StockGeneration", "Generation", "RestockTime" } do
            xpcall(function()
                folder:GetAttributeChangedSignal(key):Connect(onShopRestockDetected)
            end, noopErr)
        end
    end
    bindFolder(SeedShopFolder)
    bindFolder(GearShopFolder)
    bindFolder(StockValuesRoot)
    lastShopRestockToken = readShopRestockToken()
    lastStockSnapshot = snapshotShopStock()
    task.spawn(function()
        while true do
            task.wait(1)
            local token = readShopRestockToken()
            if token ~= lastShopRestockToken and lastShopRestockToken ~= nil and token ~= "" then
                lastShopRestockToken = token
                onShopRestockDetected()
            else
                lastShopRestockToken = token
            end
            local snap = snapshotShopStock()
            if isLikelyShopRestock(lastStockSnapshot, snap) then
                onShopRestockDetected()
            end
            lastStockSnapshot = snap
        end
    end)
end

function getMutationSpawnPosition(spawn)
    if not spawn or not spawn.Parent then return nil end
    if spawn:IsA("BasePart") then return spawn.Position end
    if spawn:IsA("Model") then return spawn:GetPivot().Position end
    local part = spawn:FindFirstChildWhichIsA("BasePart", true)
    return part and part.Position
end

function tryCollectMutationSeedsOnce()
    if not genv.ftgs_AutoCollectMutation or collectingMutation then return end
    local spawn = findMutationSeedSpawn()
    if not spawn then return end
    collectingMutation = true
    task.spawn(function()
        movementBypass = true
        gardenActionLock = true
        local hum = getHumanoid()
        local target = spawn
        while genv.ftgs_AutoCollectMutation and target and target.Parent do
            local pos = getMutationSpawnPosition(target)
            if pos then stickToPosition(pos) end
            local prompt = target:FindFirstChildWhichIsA("ProximityPrompt", true)
            if prompt then fireProximityPromptFast(prompt) end
            task.wait(0.006)
        end
        if hum then hum.PlatformStand = false end
        movementBypass = false
        gardenActionLock = false
        collectingMutation = false
    end)
end

