function startFixLag()
    stopFixLag()
    local Workspace = Services.Workspace
    local Lighting = Services.Lighting
    local MaterialService = Services.MaterialService
    local saved = { lighting = {}, instances = setmetatable({}, { __mode = "k" }) }
    local queue, qHead, qTail, qSize = {}, 1, 0, 0
    local function qPush(x) qTail += 1 queue[qTail] = x qSize += 1 end
    local function qPopBatch(n)
        local out, count = {}, math.min(n, qSize)
        for i = 1, count do out[i] = queue[qHead] queue[qHead] = nil qHead += 1 qSize -= 1 end
        return out
    end
    local function ignored(inst)
        if not inst or (LocalPlayer.Character and inst:IsDescendantOf(LocalPlayer.Character)) then return true end
        return inst:IsA("Terrain")
    end
    local function saveOnce(obj, prop, val)
        local e = saved.instances[obj] or {}
        saved.instances[obj] = e
        if e[prop] == nil then e[prop] = val end
    end
    local function optimize(inst)
        if not inst or ignored(inst) then return end
        local class = inst.ClassName
        if class == "ParticleEmitter" or class == "Trail" or class == "Smoke" or class == "Fire" or class == "Sparkles" then
            if pcall(function() return inst.Enabled end) then saveOnce(inst, "Enabled", inst.Enabled) end
            pcall(function() inst.Enabled = false end)
            return
        end
        if class == "Beam" then
            if pcall(function() return inst.Enabled end) then saveOnce(inst, "Enabled", inst.Enabled) end
            pcall(function() inst.Enabled = false end)
            return
        end
        if inst:IsA("PostEffect") then
            if pcall(function() return inst.Enabled end) then saveOnce(inst, "Enabled", inst.Enabled) end
            pcall(function() inst.Enabled = false end)
            return
        end
        if inst:IsA("MeshPart") or inst:IsA("BasePart") then
            pcall(function()
                if inst.Material then saveOnce(inst, "Material", inst.Material) inst.Material = Enum.Material.Plastic end
                if inst.Reflectance then saveOnce(inst, "Reflectance", inst.Reflectance) inst.Reflectance = 0 end
                if inst.CastShadow ~= nil then saveOnce(inst, "CastShadow", inst.CastShadow) inst.CastShadow = false end
                if inst.RenderFidelity ~= nil then saveOnce(inst, "RenderFidelity", inst.RenderFidelity) inst.RenderFidelity = 2 end
            end)
            return
        end
        if inst:IsA("Decal") or inst:IsA("Texture") then
            pcall(function() saveOnce(inst, "Transparency", inst.Transparency) inst.Transparency = 1 end)
        end
    end
    pcall(function()
        saved.lighting.GlobalShadows = Lighting.GlobalShadows
        Lighting.GlobalShadows = false
        saved.lighting.FogEnd = Lighting.FogEnd
        Lighting.FogEnd = 9e9
        local terrain = Workspace:FindFirstChildOfClass("Terrain")
        if terrain then
            saved.lighting.Terrain = {
                WaterWaveSize = terrain.WaterWaveSize,
                WaterWaveSpeed = terrain.WaterWaveSpeed,
                WaterReflectance = terrain.WaterReflectance,
                WaterTransparency = terrain.WaterTransparency,
            }
            terrain.WaterWaveSize = 0
            terrain.WaterWaveSpeed = 0
            terrain.WaterReflectance = 0
            terrain.WaterTransparency = 0
        end
        pcall(function() settings().Rendering.QualityLevel = Enum.QualityLevel.Level01 end)
        pcall(function() MaterialService.Use2022Materials = false end)
    end)
    for _, ch in Workspace:GetChildren() do qPush(ch) end
    Workspace.DescendantAdded:Connect(function(d) task.delay(0.1, function() if d then qPush(d) end end) end)
    local elapsed = 0
    fpsBoosterConn = Services.RunService.Heartbeat:Connect(function(dt)
        elapsed += dt
        if elapsed < 0.08 then return end
        elapsed = 0
        if qSize <= 0 then return end
        local batch = qPopBatch(120)
        for i = 1, #batch do
            local node = batch[i]
            if node and node.Parent then optimize(node) end
        end
    end)
    fpsBoosterRestore = function()
        for obj, props in saved.instances do
            if obj and obj.Parent then
                for prop, val in props do pcall(function() obj[prop] = val end) end
            end
        end
        for k, v in saved.lighting do
            if k == "Terrain" then
                local terrain = Workspace:FindFirstChildOfClass("Terrain")
                if terrain and type(v) == "table" then
                    for pk, pv in v do pcall(function() terrain[pk] = pv end) end
                end
            else
                pcall(function() Lighting[k] = v end)
            end
        end
    end
end

