local function patchSprinklerModules()
    if sprinklerModulesPatched then return end
    local function patchTable(tbl, depth)
        if depth > 5 or type(tbl) ~= "table" then return end
        for k, v in tbl do
            if type(k) == "string" and k:lower():find("range") and type(v) == "number" then tbl[k] = SPRINKLER_BUFF_RANGE
            elseif type(v) == "table" then patchTable(v, depth + 1) end
        end
    end
    if GearShopData and GearShopData.Data then
        for _, info in ipairs(GearShopData.Data) do
            if type(info.ItemName) == "string" and info.ItemName:find("Sprinkler") then patchTable(info, 0) end
        end
    end
    sprinklerModulesPatched = true
end

local function buffSprinklerObject(obj)
    if not obj then return end
    for _, attr in { "Range", "Radius", "MaxRange", "SprinklerRange", "EffectRange", "WaterRange" } do
        if type(obj.SetAttribute) == "function" then obj:SetAttribute(attr, SPRINKLER_BUFF_RANGE) end
    end
    for _, d in obj:GetDescendants() do
        if d:IsA("NumberValue") and d.Name:lower():find("range") then d.Value = SPRINKLER_BUFF_RANGE end
        if d:IsA("IntValue") and d.Name:lower():find("range") then d.Value = SPRINKLER_BUFF_RANGE end
    end
end

local function applySprinklerRangeBuff()
    if not genv.ftgs_BuffSprinklerRange then return end
    patchSprinklerModules()
    refreshOwnerPlot()
    if type(LocalPlayer.SetAttribute) == "function" then
        LocalPlayer:SetAttribute("SprinklerRange", SPRINKLER_BUFF_RANGE)
        LocalPlayer:SetAttribute("MaxSprinklerRange", SPRINKLER_BUFF_RANGE)
    end
    for _, obj in Services.CollectionService:GetTagged("Sprinkler") do buffSprinklerObject(obj) end
    local scanRoots = { OwnerPlot, Gardens }
    for _, root in scanRoots do
        if root then
            for _, d in root:GetDescendants() do
                if d.Name:find("Sprinkler") or d:GetAttribute("Sprinkler") or d:GetAttribute("SprinklerType") then
                    buffSprinklerObject(d)
                end
            end
        end
    end
end

