function plotUnlocked(player)
    if not player or not Gardens then return false end
    local plot
    for _, p in Gardens:GetChildren() do
        local oid = tonumber(p:GetAttribute("OwnerUserId")) or p:GetAttribute("OwnerUserId")
        if oid == player.UserId then plot = p break end
    end
    if not plot then return true end
    local area = plot:FindFirstChild("Visual") and plot.Visual:FindFirstChild("PlotSizeReferenceVisual")
    if not area then return true end
    for _, t in Services.Workspace:GetPartBoundsInBox(area.CFrame, area.Size) do
        if player.Character and t:IsDescendantOf(player.Character) then return false end
    end
    return true
end

function calculateStealValue(fruit)
    local name = fruit:GetAttribute("CorePartName") or fruit:GetAttribute("PlantName")
    local size = fruit:GetAttribute("SizeMulti") or fruit:GetAttribute("Age")
    local mut = fruit:GetAttribute("Mutation")
    local ok, val = xpcall(FruitValueCalc, noopErr, name, size, mut, LocalPlayer, 1)
    return ok and val or 0
end

function getPlotCenterPos(plot)
    if not plot then return nil end
    local psr = plot:FindFirstChild("PlotSizeReference")
    if psr and psr:IsA("BasePart") then return psr.Position end
    return plot:GetPivot().Position
end

function getStealableFruitsOnPlot(plot, limit)
    local list = {}
    if not plot then return list end
    local plants = plot:FindFirstChild("Plants")
    if not plants then return list end
    for _, plant in plants:GetChildren() do
        local fruits = plant:FindFirstChild("Fruits")
        local scan = fruits and fruits:GetChildren() or { plant }
        for _, fr in scan do
            if getStealPrompt(fr) then
                list[#list + 1] = { fruit = fr, value = calculateStealValue(fr) }
            end
        end
    end
    table.sort(list, function(a, b) return a.value > b.value end)
    local out = {}
    for i = 1, math.min(limit or STEAL_BATCH, #list) do out[#out + 1] = list[i].fruit end
    return out
end

function getPlotStealOwner(plot)
    local oid = plot:GetAttribute("OwnerUserId")
    if oid == nil or oid == 0 or oid == "" then return nil, 0 end
    local uid = tonumber(oid) or oid
    local owner = Services.Players:GetPlayerByUserId(uid)
    return owner, uid
end

function isPlotStealable(plot)
    if not plot then return false end
    local owner, uid = getPlotStealOwner(plot)
    if owner == LocalPlayer then return false end
    if owner and not plotUnlocked(owner) then return false end
    return true
end

function collectAllStealTargets()
    local targets = {}
    if not Gardens then return targets end
    for _, plot in Gardens:GetChildren() do
        if not isPlotStealable(plot) then continue end
        local owner, uid = getPlotStealOwner(plot)
        local unowned = owner == nil and uid == 0
        local fruits = getStealableFruitsOnPlot(plot, 50)
        for _, fruit in fruits do
            targets[#targets + 1] = {
                fruit = fruit,
                plot = plot,
                owner = owner,
                ownerUserId = uid,
                unowned = unowned,
                value = calculateStealValue(fruit),
            }
        end
    end
    table.sort(targets, function(a, b)
        if a.unowned ~= b.unowned then return a.unowned end
        return a.value > b.value
    end)
    return targets
end

function findBestStealPlot()
    local targets = collectAllStealTargets()
    if #targets == 0 then return nil, nil end
    return targets[1].plot, targets[1].owner
end

function fireProximityPrompt(prompt)
    if not prompt then return false end
    local fn = fireproximityprompt or rawget(genv, "fireproximityprompt")
    if type(fn) == "function" then
        if select(1, xpcall(fn, noopErr, prompt)) then return true end
        if select(1, xpcall(fn, noopErr, prompt, 0)) then return true end
    end
    if type(prompt.InputHoldBegin) ~= "function" or type(prompt.InputHoldEnd) ~= "function" then return false end
    return xpcall(function()
        prompt:InputHoldBegin()
        local hold = prompt.HoldDuration or 0
        if hold > 0 then task.wait(hold + 0.08) else task.wait(0.15) end
        prompt:InputHoldEnd()
    end, noopErr)
end

function fireProximityPromptFast(prompt)
    if not prompt then return false end
    local fn = fireproximityprompt or rawget(genv, "fireproximityprompt")
    if type(fn) == "function" then
        for _ = 1, 4 do
            xpcall(fn, noopErr, prompt)
            xpcall(fn, noopErr, prompt, 0)
        end
        return true
    end
    if type(prompt.InputHoldBegin) ~= "function" or type(prompt.InputHoldEnd) ~= "function" then return false end
    return xpcall(function()
        for _ = 1, 3 do
            prompt:InputHoldBegin()
            task.wait(0.012)
            prompt:InputHoldEnd()
        end
    end, noopErr)
end

function isMutationSeedSpawn(spawn)
    if not spawn then return false end
    return spawn:GetAttribute("RainbowSeed") == true
        or spawn:GetAttribute("GoldSeed") == true
        or spawn:GetAttribute("MegaSeed") == true
end

function findMutationSeedSpawn()
