            if seedNamesMatch(sn, name) then n += 1 end
        end
    end
    scan(LocalPlayer.Character)
    scan(LocalPlayer:FindFirstChild("Backpack"))
    return n
end

function getOccupiedPlantPositions()
    local positions = {}
    refreshOwnerPlot()
    local pf = OwnerPlot and OwnerPlot:FindFirstChild("Plants")
    if not pf then return positions end
    for _, plant in pf:GetChildren() do
        local part = plant.PrimaryPart or plant:FindFirstChildWhichIsA("BasePart", true)
        if part then positions[#positions + 1] = part.Position end
    end
    return positions
end

function isSpotEmpty(pos, occupied)
    for _, p in occupied do
        if (Vector3.new(p.X, 0, p.Z) - Vector3.new(pos.X, 0, pos.Z)).Magnitude < PLANT_MIN_DIST then return false end
    end
    return true
end

function findPlantAreaPosition(nearPos)
    if #plantAreas == 0 then refreshPlantAreas() end
    if #plantAreas == 0 or not nearPos then return nil end
    local bestPos, bestDist
    for _, pos in plantAreas do
        local d = (Vector3.new(pos.X, 0, pos.Z) - Vector3.new(nearPos.X, 0, nearPos.Z)).Magnitude
        if not bestDist or d < bestDist then bestPos, bestDist = pos, d end
    end
    return bestPos
end

function isNearPlotCenter(pos)
    refreshOwnerPlot()
    if not savedPlotCenter or not pos then return false end
    return flatDistXZ(pos, savedPlotCenter) < PLANT_CENTER_AVOID
end

function findNearestEmptySpotOnPlot()
    refreshOwnerPlot()
    if #plantAreas == 0 then refreshPlantAreas() end
    if #plantAreas == 0 then return nil end
    local occupied = getOccupiedPlantPositions()
    local best, bestEdge
    for _, pos in plantAreas do
        if not isSpotEmpty(pos, occupied) then continue end
        if isNearPlotCenter(pos) then continue end
        local edge = savedPlotCenter and flatDistXZ(pos, savedPlotCenter) or 0
        if not best or edge > bestEdge then
            best, bestEdge = pos, edge
        end
    end
    if best then return findPlantAreaPosition(best) or best end
    for _, pos in plantAreas do
        if isSpotEmpty(pos, occupied) and not isNearPlotCenter(pos) then
            return findPlantAreaPosition(pos) or pos
        end
    end
    return nil
end

function findEmptyGardenSpotNearPlayer()
    refreshOwnerPlot()
    if #plantAreas == 0 then refreshPlantAreas() end
    if not isInGardenActionRange() then return nil end
    return findNearestEmptySpotOnPlot()
end

function extractPlantDataPosition(plantData)
    if type(plantData) ~= "table" then return nil end
    local positions = plantData.Positions or plantData.Position
    if typeof(positions) == "Vector3" then return positions end
    if type(positions) == "table" then
        local x = positions.PosX or positions.X or positions.x
        local y = positions.PosY or positions.Y or positions.y
        local z = positions.PosZ or positions.Z or positions.z
        if x and y and z then return Vector3.new(x, y, z) end
    end
    return nil
end

function isSprinklerSpotTaken(pos, plantKey)
    if plantKey and sprinkledPlantKeys[plantKey] then return true end
    for _, s in sprinkledSpots do
        if flatDistXZ(pos, s) < SPRINKLER_MIN_DIST then return true end
    end
    return false
end

function findBestSprinklerSpotNearPlayer()
    refreshOwnerPlot()
    local playerFlat = getPlayerFlatPos()
    if not playerFlat then return nil end

    local candidates = {}
    local function addCandidate(rawPos, seed, plantKey)
        if not rawPos or not seed then return end
        local spot = findPlantAreaPosition(rawPos) or rawPos
        if isSprinklerSpotTaken(spot, plantKey) then return end
        local dist = flatDistXZ(spot, playerFlat)
        if dist > NEAR_PLAYER_DIST and not isInGardenActionRange() then return end
        local rank = getRarityRank(getSeedRarity(seed))
        local valueScore = (9 - math.min(rank, 8)) * 1000 + getSeedPrice(seed)
        candidates[#candidates + 1] = { pos = spot, score = valueScore - dist * 20, plantKey = plantKey }
    end

    for plantId, pd in pairs(trackedPlants) do
        local seed = getPlantSeedName(pd)
        if seed then addCandidate(extractPlantDataPosition(pd), seed, tostring(plantId)) end
    end

    local pf = OwnerPlot and OwnerPlot:FindFirstChild("Plants")
    if pf then
        for _, plant in pf:GetChildren() do
            local seed = plant:GetAttribute("SeedName") or plant:GetAttribute("PlantName")
            if seed then
                local part = plant.PrimaryPart or plant:FindFirstChildWhichIsA("BasePart", true)
                if part then
                    local pid = plant:GetAttribute("PlantId") or plant.Name
                    addCandidate(part.Position, seed, tostring(pid))
                end
            end
        end
    end

    table.sort(candidates, function(a, b) return a.score > b.score end)
    if candidates[1] then return candidates[1].pos, candidates[1].plantKey end

    local hrp = getRoot()
    if hrp then
        local y = savedPlotCenter and savedPlotCenter.Y or hrp.Position.Y
        local fallback = findPlantAreaPosition(hrp.Position) or Vector3.new(hrp.Position.X, y, hrp.Position.Z)
        if not isSprinklerSpotTaken(fallback, nil) then return fallback end
    end
    return nil
end

