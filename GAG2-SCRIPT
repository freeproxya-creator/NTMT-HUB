        return Services.HttpService:JSONDecode(universalHttpGet(
            "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
        ))
    end, noopErr)
    if not ok or not servers or not servers.data then return end
    local job = game.JobId
    local candidates = {}
    for _, s in servers.data do
        if s.id ~= job and s.playing and s.playing < (s.maxPlayers or 50) then candidates[#candidates + 1] = s.id end
    end
    if #candidates == 0 then return end
    Services.TeleportService:TeleportToPlaceInstance(game.PlaceId, candidates[math.random(1, #candidates)], LocalPlayer)
end

