        if genv.ftgs_AutoFindPet and not petFindBusy then
            petFindBusy = true
            initMapFolders()
            if type(WindUI.Notify) == "function" then
                WindUI:Notify({ Title = "Pet Finder", Content = "Scanning for " .. selectedFindPet .. "...", Icon = "search", Duration = 3 })
            end
            local found = false
            for _ = 1, math.floor(PET_FIND_SCAN_SEC / 0.5) do
                if not genv.ftgs_AutoFindPet then break end
                if scanServerForPet(selectedFindPet) then found = true break end
                task.wait(0.5)
            end
            if found then
                genv.ftgs_AutoFindPet = false
                if type(WindUI.Notify) == "function" then
                    WindUI:Notify({ Title = "Pet Found!", Content = selectedFindPet .. " on this server", Icon = "check", Duration = 8 })
                end
            elseif genv.ftgs_AutoFindPet then
                if type(WindUI.Notify) == "function" then
                    WindUI:Notify({ Title = "Pet Finder", Content = "Not found. Hopping...", Icon = "shuffle", Duration = 3 })
                end
                task.wait(3)
                if genv.ftgs_AutoFindPet then hopToRandomServer() end
                task.wait(12)
            end
            petFindBusy = false
        else task.wait(1) end
    end
end)

