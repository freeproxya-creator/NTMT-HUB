function findHighestValueFruitTarget()
    local bestFruit, bestVal, bestPart
    if not Gardens then return nil end
    for _, plot in Gardens:GetChildren() do
        local plants = plot:FindFirstChild("Plants")
        if not plants then continue end
        for _, plant in plants:GetChildren() do
            local fruits = plant:FindFirstChild("Fruits")
            local scan = fruits and fruits:GetChildren() or { plant }
            for _, fr in scan do
                local part = fr:IsA("BasePart") and fr or fr:FindFirstChildWhichIsA("BasePart", true)
                if part then
                    local val = calculateStealValue(fr)
                    if not bestVal or val > bestVal then
                        bestFruit, bestVal, bestPart = fr, val, part
                    end
                end
            end
        end
    end
    if bestFruit then return bestFruit, bestPart, bestVal end
    return nil
end

