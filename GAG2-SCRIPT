local function dumpGetIconsSnippet(body)
    if type(body) ~= "string" then return end
    local idx = body:find("GetIcons", 1, true)
    if not idx then
        hubWarn("Patch check: GetIcons string NOT found in WindUI body")
        return
    end
    hubWarn("Patch check: GetIcons context:", body:sub(math.max(1, idx - 60), math.min(#body, idx + 100)))
end

local function patchWindUISource(body)
    if type(body) ~= "string" then return body, false end
    local replacement = "local d=b({Icons={}})"
    local exact = 'local d=b(game:GetService"ReplicatedStorage":WaitForChild("GetIcons",99999):InvokeServer())'
    local s, e = body:find(exact, 1, true)
    if s then
        body = body:sub(1, s - 1) .. replacement .. body:sub(e + 1)
    end
    body = body:gsub(
        'function a%.b%(%)%s*local b=%(cloneref or clonereference or function%(b%)return b end%)%s*local d=b%(game:GetService"ReplicatedStorage":WaitForChild%("GetIcons",%d+%):InvokeServer%(%)%)',
        'function a.b() local b=(cloneref or clonereference or function(b)return b end) local d=b({Icons={}})'
    )
    body = body:gsub(
        'local d=b%(game:GetService"ReplicatedStorage":WaitForChild%("GetIcons",%d+%):InvokeServer%(%)%)',
        replacement
    )
    body = body:gsub(
        'b%(game:GetService"ReplicatedStorage":WaitForChild%("GetIcons",%d+%):InvokeServer%(%)%)',
        'b({Icons={}})'
    )
    body = body:gsub(
        'game:GetService"ReplicatedStorage":WaitForChild%("GetIcons",%d+%):InvokeServer%(%)',
        '({Icons={}})'
    )
    body = body:gsub('WaitForChild%("GetIcons",%d+%):InvokeServer%(%)', '({Icons={}})')
    body = body:gsub('GetIcons.-:InvokeServer%(%)', '{Icons={}}')
    local stillBad = body:find('GetIcons.-InvokeServer%(%)') ~= nil
    return body, not stillBad
end

local function windUISourceClean(body)
    return type(body) == "string" and not body:find("GetIcons.-InvokeServer%(%)")
end

local function compileWindUIChunk(body)
    publishWindUIGlobals()
    local env = setmetatable({}, {
        __index = function(_, key)
            local v = genv[key]
            if v ~= nil then return v end
            return _G[key]
        end,
        __newindex = function(_, key, val)
            genv[key] = val
            _G[key] = val
        end,
    })
    if type(loadstring) == "function" then
        local chunk, err = loadstring(body, "WindUI")
        if type(chunk) ~= "function" then return nil, err end
        if setfenv then
            setfenv(chunk, env)
        end
        return chunk
    end
    if type(load) == "function" then
        return load(body, "WindUI", "t", env)
    end
    return nil, "no loadstring/load"
end

