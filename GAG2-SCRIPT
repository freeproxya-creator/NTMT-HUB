function holdGardenStill(duration)
    refreshOwnerPlot()
    if not savedPlotCenter then return end
    local cf = CFrame.new(savedPlotCenter + Vector3.new(0, 3, 0))
    gardenActionLock = true
    movementBypass = true
    local deadline = os.clock() + (duration or 0.5)
    while os.clock() < deadline do
        local hrp = getRoot()
