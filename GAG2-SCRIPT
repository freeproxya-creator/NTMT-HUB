    if not SeedPackSpawns then return nil end
    for _, spawn in SeedPackSpawns:GetChildren() do
        if isMutationSeedSpawn(spawn) and spawn.Parent then return spawn end
    end
    return nil
end

function stealFruit(fruit, ownerUserId, sessionId)
    if not genv.ftgs_AutoSteal or sessionId ~= stealSessionId then return false end
    if not fruit or not fruit.Parent then return false end
    local stealPos, uid, plantId, fruitId = resolveStealTarget(fruit, ownerUserId)
    if not stealPos or not plantId then return false end
    if not uid or uid == 0 then
        uid = tonumber(fruit:GetAttribute("UserId")) or tonumber(fruit:GetAttribute("OwnerUserId"))
    end
    if not uid or uid == 0 then return false end

    local fruitCountBefore = getFruitCount()
    movementBypass = true
    gardenActionLock = true
    local deadline = os.clock() + STEAL_HOLD_TIMEOUT

    while os.clock() < deadline do
        if not genv.ftgs_AutoSteal or sessionId ~= stealSessionId then break end
        if isStealComplete(fruit, fruitCountBefore) then break end
        if not fruit.Parent then break end
        briefTpForAction(stealPos)
        local prompt = getStealPrompt(fruit)
        if prompt then fireProximityPrompt(prompt) end
        safeNetCall(Net.Steal and Net.Steal.BeginSteal, uid, plantId, fruitId)
        safeNetCall(Net.Steal and Net.Steal.CompleteSteal)
        task.wait(STEAL_TICK)
    end

    movementBypass = false
    gardenActionLock = false

    if not genv.ftgs_AutoSteal or sessionId ~= stealSessionId then return false end

    if isStealComplete(fruit, fruitCountBefore) then
        StolenFruits[#StolenFruits + 1] = { name = fruit.Name .. " (" .. tostring(calculateStealValue(fruit)) .. ")", time = os.time() }
        saveConfig()
        return true
    end
    return false
end

function tryAutoSteal()
    if not genv.ftgs_AutoSteal or stealBusy or isInventoryFull() then return end
    stealBusy = true
    local sessionId = stealSessionId
    task.spawn(function()
        safeNetCall(Net.Garden and Net.Garden.RequestGardens)
        task.wait(0.03)
        movementBypass = true
        local targets = collectAllStealTargets()
        local stolen = 0
        for _, t in ipairs(targets) do
            if not genv.ftgs_AutoSteal or sessionId ~= stealSessionId then break end
            if stolen >= STEAL_BATCH or isInventoryFull() then break end
            if t.owner and not plotUnlocked(t.owner) then continue end
            local uid = t.ownerUserId
            if t.owner then uid = t.owner.UserId end
            if stealFruit(t.fruit, uid, sessionId) then stolen += 1 end
            if stolen >= STEAL_BATCH then break end
            task.wait(0.03)
        end
        if stolen > 0 and genv.ftgs_AutoSteal and sessionId == stealSessionId then
            returnToGarden()
            task.wait(0.08)
        end
        if sessionId == stealSessionId then
            movementBypass = false
            stealBusy = false
        end
    end)
end

