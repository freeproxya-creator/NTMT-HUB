function tryDefendPetAt(pos)
    if not genv.ftgs_AutoDefendPet or not pos then return false end
    local intruders = getPlayersNearPosition(pos, PET_DEFEND_RADIUS)
    local shovel = select(1, findGearTool("Shovel", { "Advanced Shovel", "Common Shovel" }))
    if shovel and #intruders > 0 then equipTool(shovel) end
    updateDefendHitboxes(pos)
    if #intruders == 0 then return false end
    for _, target in intruders do
        hitPlayerWithShovel(target, shovel)
