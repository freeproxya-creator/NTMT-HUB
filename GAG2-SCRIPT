local function installGetIconsHook()
    cleanupBrokenGetIcons()
    if not (hookmetamethod and getnamecallmethod and newcclosure) then return end
    pcall(function()
        local RS = game:GetService("ReplicatedStorage")
        local iconsPayload = { Icons = {} }
        local mock = setmetatable({}, {
            __index = function(_, key)
                if key == "InvokeServer" then return function() return iconsPayload end end
                if key == "Name" then return "GetIcons" end
                if key == "Parent" then return RS end
                return nil
            end,
        })
        local oldNamecall
        oldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
            local method = getnamecallmethod()
            if method == "WaitForChild" and self == RS and select(1, ...) == "GetIcons" then
                return mock
            end
            return oldNamecall(self, ...)
        end))
    end)
end

local function patchWindUISource(body)
    if type(body) ~= "string" then return body, false end
    local replacement = "local d=b({Icons={}})"
    local exact = 'local d=b(game:GetService"ReplicatedStorage":WaitForChild("GetIcons",99999):InvokeServer())'
    local s, e = body:find(exact, 1, true)
    if s then
        body = body:sub(1, s - 1) .. replacement .. body:sub(e + 1)
    else
        body = body:gsub(
            'local d=b%(game:GetService"ReplicatedStorage":WaitForChild%("GetIcons",%d+%):InvokeServer%(%)%)',
            replacement
        )
    end
    local stillBad = body:find(':WaitForChild%("GetIcons",%d+%):InvokeServer%(%)') ~= nil
    return body, not stillBad
end

local function compileWindUIChunk(body)
    if type(loadstring) == "function" then
        local chunk, err = loadstring(body, "WindUI")
        if type(chunk) ~= "function" then return nil, err end
        return chunk
    end
    if type(load) == "function" then
        return load(body, "WindUI", "t", genv)
    end
    return nil, "no loadstring/load"
end

