function resolveRefFromModel(model)
    if not model or not WildPetFolder then return nil end
    local refName = string.match(model.Name, "^WildPet_.-_(.+)$")
    local ref = refName and WildPetFolder:FindFirstChild(refName)
    if ref and ref:IsA("BasePart") then return ref end
    for _, ch in WildPetFolder:GetChildren() do
        if ch:IsA("BasePart") and model.Name:find(ch.Name, 1, true) then return ch end
    end
    return nil
end

