function getPlayersNearPosition(pos, radius)
    local out = {}
    if not pos then return out end
    for _, plr in Services.Players:GetPlayers() do
        if plr ~= LocalPlayer and plr.Character then
            local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
            if hrp and (hrp.Position - pos).Magnitude <= radius then
                out[#out + 1] = plr
            end
        end
    end
    table.sort(out, function(a, b)
        local ah = a.Character and a.Character:FindFirstChild("HumanoidRootPart")
        local bh = b.Character and b.Character:FindFirstChild("HumanoidRootPart")
        if not ah or not bh then return false end
        return (ah.Position - pos).Magnitude < (bh.Position - pos).Magnitude
    end)
    return out
end

function findExactBodyPart(char, partName)
    if not char then return nil end
    local want = string.lower(partName)
    for _, part in char:GetChildren() do
        if part:IsA("BasePart") and string.lower(part.Name) == want then return part end
    end
    return nil
end

function saveHitboxPart(plr, part)
    if not hitboxOriginalProps[plr] then hitboxOriginalProps[plr] = {} end
    if not hitboxOriginalProps[plr][part.Name] then
        hitboxOriginalProps[plr][part.Name] = {
            CanCollide = part.CanCollide,
            Transparency = part.Transparency,
            Size = part.Size,
        }
    end
end

function extendPlayerHitbox(plr)
    if not plr or not plr.Character then return end
    for _, partName in HITBOX_BODY_PARTS do
        local part = findExactBodyPart(plr.Character, partName)
        if part then
            saveHitboxPart(plr, part)
            part.CanCollide = true
            part.Transparency = HITBOX_TRANSPARENCY
            part.Size = Vector3.new(HITBOX_SIZE, HITBOX_SIZE, HITBOX_SIZE)
        end
    end
end

function restorePlayerHitbox(plr)
    local saved = hitboxOriginalProps[plr]
    if not saved then return end
    if plr.Character then
        for partName, props in saved do
            local part = plr.Character:FindFirstChild(partName)
            if part and part:IsA("BasePart") then
                part.CanCollide = props.CanCollide
                part.Transparency = props.Transparency
                part.Size = props.Size
            end
        end
    end
    hitboxOriginalProps[plr] = nil
end

function restoreAllHitboxes()
    for _, plr in Services.Players:GetPlayers() do restorePlayerHitbox(plr) end
    hitboxOriginalProps = {}
    defendHitboxActive = false
end

function updateDefendHitboxes(petPos)
    if not genv.ftgs_AutoDefendPet or not isCatchingPet or not petPos then
        if defendHitboxActive then restoreAllHitboxes() end
        return
    end
    defendHitboxActive = true
    for _, plr in Services.Players:GetPlayers() do
        if plr ~= LocalPlayer and plr.Character then
            local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
            if hrp and (hrp.Position - petPos).Magnitude <= PET_DEFEND_RADIUS + 15 then
                extendPlayerHitbox(plr)
            else
                restorePlayerHitbox(plr)
            end
        end
    end
end

