                        for _, v in ipairs(values) do if picked[v] then parts[#parts + 1] = v end end
                        lbl.Text = (d.Title or "Select") .. hint .. "\n" .. (#parts > 0 and table.concat(parts, ", ") or "none")
                    else
                        lbl.Text = (d.Title or "Select") .. hint .. "\n" .. tostring(values[idx] or "?")
                    end
                end
                refresh()
                row.MouseButton1Click:Connect(function()
                    if #values == 0 then return end
                    local v = values[idx]
                    if d.Multi then
                        picked[v] = not picked[v]
                        if not picked[v] then picked[v] = nil end
                        if d.Callback then d.Callback(picked) end
                    elseif d.Callback then
                        d.Callback(v)
                    end
                    idx = idx % #values + 1
                    refresh()
                end)
            end

