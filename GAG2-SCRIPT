function hitPlayerWithShovel(targetPlr, shovelTool)
    if not targetPlr or not targetPlr.Character then return end
    extendPlayerHitbox(targetPlr)
    local shovel = shovelTool or select(1, findGearTool("Shovel", { "Advanced Shovel", "Common Shovel" }))
    if not shovel then return end
    equipTool(shovel)
    shovel = select(1, findGearTool("Shovel", { "Advanced Shovel", "Common Shovel" })) or shovel
    local thrp = targetPlr.Character:FindFirstChild("HumanoidRootPart")
