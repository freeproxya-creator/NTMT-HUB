task.spawn(function()
    while true do
        if genv.ftgs_BypassMovement and not movementBypass and not gardenActionLock and not isCatchingPet and not stealBusy then
            local hrp = getRoot()
            local hum = getHumanoid()
            if hrp and hum and lastKnownMoveCF and hum.MoveDirection.Magnitude > 0.08 then
                local snap = (hrp.Position - lastKnownMoveCF.Position).Magnitude
                if snap > 8 then
                    local dir = hum.MoveDirection
                    if dir.Magnitude > 0.05 then
                        local flat = Vector3.new(dir.X, 0, dir.Z).Unit
                        local push = lastKnownMoveCF.Position + flat * desiredWalkSpeed * 0.05
                        hrp.CFrame = CFrame.new(push + Vector3.new(0, 3, 0))
                    else
                        hrp.CFrame = lastKnownMoveCF
                    end
                    local vel = Vector3.new(dir.X * desiredWalkSpeed, hrp.AssemblyLinearVelocity.Y, dir.Z * desiredWalkSpeed)
                    hrp.AssemblyLinearVelocity = vel
                    hrp.AssemblyAngularVelocity = Vector3.zero
                    pcall(function() hrp.Velocity = vel end)
                end
            end
        end
        task.wait(0.02)
    end
end)

