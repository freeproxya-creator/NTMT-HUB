function setupShopRestockWatch()
    local function bindFolder(folder)
        if not folder then return end
        for _, key in { "RestockToken", "RestockId", "StockGeneration", "Generation", "RestockTime" } do
            xpcall(function()
                folder:GetAttributeChangedSignal(key):Connect(onShopRestockDetected)
            end, noopErr)
        end
    end
    bindFolder(SeedShopFolder)
    bindFolder(GearShopFolder)
    bindFolder(StockValuesRoot)
    lastShopRestockToken = readShopRestockToken()
    lastStockSnapshot = snapshotShopStock()
    task.spawn(function()
        while true do
            task.wait(1)
            local token = readShopRestockToken()
            if token ~= lastShopRestockToken and lastShopRestockToken ~= nil and token ~= "" then
                lastShopRestockToken = token
                onShopRestockDetected()
            else
                lastShopRestockToken = token
            end
            local snap = snapshotShopStock()
            if isLikelyShopRestock(lastStockSnapshot, snap) then
                onShopRestockDetected()
            end
            lastStockSnapshot = snap
        end
    end)
end

