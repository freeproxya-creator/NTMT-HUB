function getStealPrompt(fruit)
    if not fruit then return nil end
    local hp = fruit:FindFirstChild("HarvestPart") or fruit.PrimaryPart or fruit:FindFirstChildWhichIsA("BasePart")
    if hp then
        local prompt = hp:FindFirstChild("StealPrompt")
        if prompt and not prompt:IsA("ProximityPrompt") then
            prompt = prompt:IsA("ObjectValue") and prompt.Value or hp:FindFirstChildWhichIsA("ProximityPrompt")
        end
        if prompt then return prompt end
        prompt = hp:FindFirstChildWhichIsA("ProximityPrompt")
        if prompt then return prompt end
    end
    for _, desc in fruit:GetDescendants() do
        if desc:IsA("ProximityPrompt") then
            local action = (desc.ActionText or ""):lower()
            if action:find("steal", 1, true) or desc.Name == "StealPrompt" then return desc end
        end
    end
    return nil
end

function resolveStealTarget(fruit, ownerUserId)
    local hp = fruit:FindFirstChild("HarvestPart") or fruit.PrimaryPart or fruit:FindFirstChildWhichIsA("BasePart", true)
    local stealPos = hp and hp.Position
    local uid = ownerUserId or tonumber(fruit:GetAttribute("UserId")) or tonumber(fruit:GetAttribute("OwnerUserId"))
    local plantId = fruit:GetAttribute("PlantId") or fruit:GetAttribute("PlantID")
    local fruitId = fruit:GetAttribute("FruitId") or fruit:GetAttribute("FruitID") or ""
    if not plantId and fruit.Parent and fruit.Parent.Name == "Fruits" then
        local plantModel = fruit.Parent.Parent
        if plantModel then plantId = plantModel:GetAttribute("PlantId") or plantModel:GetAttribute("PlantID") end
    end
    if not plantId then
        local anc = fruit:FindFirstAncestorWhichIsA("Model")
        if anc then plantId = anc:GetAttribute("PlantId") or anc:GetAttribute("PlantID") or anc.Name end
    end
    return stealPos, uid, plantId, fruitId, hp
end

