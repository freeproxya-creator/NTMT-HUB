    if thrp and hrp then
        local offset = (hrp.Position - thrp.Position).Magnitude > 1 and (hrp.Position - thrp.Position).Unit * 3.5 or Vector3.new(0, 0, 3.5)
        hrp.CFrame = CFrame.new(thrp.Position + offset + Vector3.new(0, 2, 0))
